# =====================================================================
# Personal Cognitive Operating System - Environment Variables
# Copy this file to ".env.local" for local development. For production,
# add the same vars in the Vercel dashboard (Project -> Settings ->
# Environment Variables).
# =====================================================================

# --- Gemini (required) ---
# Get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
# gemini-2.5-flash is on the free tier and can read YouTube URLs
# directly via fileData. gemini-2.5-pro requires billing enabled on
# your Google Cloud project (free quota is 0). Stick with flash unless
# you have a paid plan and need stronger reasoning.
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (required) ---
# Create a free project at https://supabase.com -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- YouTube Data API v3 (required for the curated feed) ---
# Free tier 10k units/day. Used by /api/feed/generate to discover and
# enrich videos (search.list + videos.list). Without this, the feed
# falls back to RSS only.
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# --- App ---
# Public URL of your deployed app. Used for absolute links in PDFs etc.
# Local: http://localhost:3000
# Production on Vercel: https://<your-project>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
